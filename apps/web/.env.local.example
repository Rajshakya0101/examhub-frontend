# Firebase Config
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# OpenAI
VITE_OPENAI_API_KEY=your-openai-api-key

# Pinecone/Vertex AI
VITE_PINECONE_API_KEY=your-pinecone-api-key
VITE_PINECONE_ENVIRONMENT=your-environment
VITE_PINECONE_INDEX=your-index-name

# Analytics & Monitoring 
VITE_GA_ID=your-ga-id
VITE_SENTRY_DSN=your-sentry-dsn

# Quick Quiz API
VITE_QUIZ_API_BASE_URL=https://examhub-2.onrender.com/api/v2

# Mathematics Quick Quiz API (Hugging Face)
VITE_MATHEMATICS_QUIZ_API_ENDPOINT=https://pranova-new-mcq-api.hf.space/generate_mock
# Optional: set only if you want repeatable question sets for testing.
# Leave unset to use a new random seed on every request.
VITE_MATHEMATICS_QUIZ_SEED=10