# OpenAI API Key for AI question generation
OPENAI_API_KEY=your-openai-api-key

# Optional: Vector database for similar question search (Pinecone)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=your-pinecone-environment
PINECONE_INDEX=your-pinecone-index

# PDF report generation settings
PDF_QUALITY=100
PDF_PAGE_SIZE=A4

# Google Cloud Storage settings
GCS_BUCKET=your-project-id.appspot.com

# Optional: Sentiment analysis for user feedback
SENTIMENT_ANALYSIS_ENABLED=false